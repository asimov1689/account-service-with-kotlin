# Exclude build scripts and generated files from language statistics
*.sh linguist-vendored
*.bat linguist-vendored
gradlew linguist-vendored
gradlew.bat linguist-vendored

# Exclude documentation and build-related files
build/ linguist-vendored
.gradle/ linguist-vendored
*.html linguist-documentation
*.css linguist-vendored
*.js linguist-vendored

# Keep only Kotlin and Java as source languages
*.kt linguist-language=Kotlin
*.java linguist-language=Java

